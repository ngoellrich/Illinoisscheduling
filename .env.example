# ---- Database (Postgres) ----------------------------------------------------
# Local dev example: postgresql://postgres:postgres@localhost:5432/solar
# On Render, paste the Internal Database URL from your Postgres instance.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/solar?schema=public"

# ---- App ---------------------------------------------------------------------
# Public base URL of the app. Used for magic links + OAuth redirect.
# Local: http://localhost:3000   Render: https://your-app.onrender.com
APP_URL="http://localhost:3000"

# Secret used to sign sessions & magic-link tokens. Generate with:
#   openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Comma-separated emails that should be granted ADMIN on first login.
ADMIN_EMAILS="goellrichcorp@gmail.com"

# Business timezone (IANA). Availability + slots are interpreted in this zone.
BUSINESS_TIMEZONE="America/Chicago"

# Default appointment length, used only when an intake event has no end time.
APPOINTMENT_MINUTES="60"

# Secret protecting the /api/cron endpoint (push-channel renewal + safety sync).
# Generate with: openssl rand -base64 32
CRON_SECRET="change-me-too"

# ---- Google OAuth (per-rep calendar access) ---------------------------------
# Create at https://console.cloud.google.com → APIs & Services → Credentials.
# Authorized redirect URI must be: {APP_URL}/api/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Email (magic links + optional notifications) ---------------------------
# SMTP. For Resend: host=smtp.resend.com, user=resend, pass=YOUR_API_KEY.
# Leave SMTP_HOST blank in dev to print magic links to the server console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Solar Scheduler <noreply@example.com>"
